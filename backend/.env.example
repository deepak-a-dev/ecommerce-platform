# Copy these into your IntelliJ run configuration's "Environment variables".
# Real values must NEVER be committed.

DB_URL=jdbc:mysql://localhost:3306/ecommerce_platform
DB_USERNAME=root
DB_PASSWORD=your_local_db_password

MAIL_USERNAME=your_sender@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Generate a new 256-bit hex secret, e.g.:  openssl rand -hex 32
JWT_SECRET=replace_me_with_a_freshly_generated_secret

# Initial admin account (seeded on first startup if it doesn't already exist)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=choose_a_strong_admin_password